PORT=5050
MONGO_URI=
# Allowed frontend origin(s) for CORS in production (comma-separated)
CLIENT_URL=
# Example: https://kyc-frontend-pied.vercel.app,https://www.yoursite.com
CLIENT_URLS=

# Comma/space-separated admin emails (auto-promoted on login)
ADMIN_EMAIL=mehulsain1603@gmail.com, indomehul@gmail.com

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Firebase Admin SDK
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Keep literal \n in the key when storing in .env
FIREBASE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n

# OCR tuning (optional)
OCR_DOWNLOAD_TIMEOUT_MS=45000
